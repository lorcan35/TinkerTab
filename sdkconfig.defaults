# TinkerClaw Tab5 — ESP32-P4 defaults (Phase 1.5)
# Matched to M5Stack Tab5 BSP sdkconfig

# Flash — Tab5 has 16MB QIO flash
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# Compiler — performance optimized
CONFIG_COMPILER_OPTIMIZATION_PERF=y

# PSRAM — 200MHz, XIP enabled (critical for MIPI DSI framebuffer DMA)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_SPEED_200M=y
CONFIG_SPIRAM_XIP_FROM_PSRAM=y

# L2 Cache — 256KB with 128-byte lines (needed for DSI video streaming)
CONFIG_CACHE_L2_CACHE_256KB=y
CONFIG_CACHE_L2_CACHE_LINE_128B=y

# Larger main task stack (display + LVGL + all driver inits need room)
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384

# FreeRTOS tick rate
CONFIG_FREERTOS_HZ=1000

# Task WDT — 60s timeout (settings screen creation takes 5-10s with feed_wdt yields)
CONFIG_ESP_TASK_WDT_TIMEOUT_S=60

# Partition table — custom for 16MB flash (4MB app + 12MB storage)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# USB console (JTAG/serial)
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# Experimental features (required for some MIPI DSI APIs)
CONFIG_IDF_EXPERIMENTAL_FEATURES=y

# ---------------------------------------------------------------------------
# ESP-Hosted — ESP32-C6 WiFi co-processor via SDIO
# Requires ESP-IDF v5.4.3+ for PSRAM XIP + TCM stack fixes
# ---------------------------------------------------------------------------
# Tab5 SDIO pin mapping (different from P4 EV Board defaults!)
CONFIG_ESP_HOSTED_SDIO_PIN_CLK=12
CONFIG_ESP_HOSTED_SDIO_PIN_CMD=13
CONFIG_ESP_HOSTED_SDIO_PIN_D0=11
CONFIG_ESP_HOSTED_SDIO_PRIV_PIN_D1_4BIT_BUS=10
CONFIG_ESP_HOSTED_SDIO_PIN_D2=9
CONFIG_ESP_HOSTED_SDIO_PIN_D3=8
CONFIG_ESP_HOSTED_SDIO_GPIO_RESET_SLAVE=15
# Tab5 C6 reset is active LOW (confirmed from M5Stack UserDemo sdkconfig)
CONFIG_ESP_HOSTED_SDIO_RESET_ACTIVE_LOW=y
# Slave target is ESP32-C6
CONFIG_ESP_HOSTED_IDF_SLAVE_TARGET="esp32c6"
CONFIG_SLAVE_IDF_TARGET_ESP32C6=y

# ---------------------------------------------------------------------------
# WiFi credentials and Dragon server (overridable via menuconfig)
# ---------------------------------------------------------------------------
CONFIG_TAB5_WIFI_SSID="YOUR_WIFI_SSID"
CONFIG_TAB5_WIFI_PASS="YOUR_WIFI_PASS"
CONFIG_TAB5_DRAGON_HOST="192.168.1.91"
CONFIG_TAB5_DRAGON_PORT=3502

# ---------------------------------------------------------------------------
# LVGL Configuration
# ---------------------------------------------------------------------------
CONFIG_LV_COLOR_DEPTH_16=y
CONFIG_LV_FONT_MONTSERRAT_12=y
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_FONT_MONTSERRAT_16=y
CONFIG_LV_FONT_MONTSERRAT_18=y
CONFIG_LV_FONT_MONTSERRAT_20=y
CONFIG_LV_FONT_MONTSERRAT_24=y
CONFIG_LV_FONT_MONTSERRAT_28=y
CONFIG_LV_FONT_MONTSERRAT_36=y
CONFIG_LV_FONT_MONTSERRAT_48=y
CONFIG_LV_USE_LOG=y
CONFIG_LV_LOG_LEVEL_WARN=y
CONFIG_LV_THEME_DEFAULT_DARK=y
CONFIG_LV_DRAW_SW_CIRCLE_CACHE_SIZE=32
# LVGL memory — 96KB base + 1024KB expand = 1120KB total capacity.
# 96KB is max safe BSS size for internal SRAM. Expand uses system heap (PSRAM).
CONFIG_LV_MEM_SIZE_KILOBYTES=96
CONFIG_LV_MEM_POOL_EXPAND_SIZE_KILOBYTES=1024
# Disable LVGL assert on malloc failure — default while(1) hangs 60s then WDT kills device
CONFIG_LV_USE_ASSERT_NULL=n
CONFIG_LV_USE_ASSERT_MALLOC=n

# ---------------------------------------------------------------------------
# Crash diagnostics and stability
# ---------------------------------------------------------------------------
CONFIG_ESP_COREDUMP_ENABLE_TO_FLASH=y
CONFIG_ESP_COREDUMP_DATA_FORMAT_ELF=y
CONFIG_ESP_COREDUMP_MAX_TASKS_NUM=64
CONFIG_ESP_COREDUMP_CHECKSUM_CRC32=y
CONFIG_ESP_COREDUMP_ENABLE_TO_NONE=
CONFIG_ESP_TASK_WDT_PANIC=y
CONFIG_HEAP_POISONING_DISABLED=y
CONFIG_HEAP_POISONING_LIGHT=
# IDLE task needs more stack for vTaskDelete cleanup on Core 1 (#18)
CONFIG_FREERTOS_IDLE_TASK_STACKSIZE=4096
CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=4096
# Disable TLSP deletion callbacks — esp_ptr_executable() false positive on P4
# with PSRAM XIP (.text at 0x4800xxxx not recognized as executable) (#18)
CONFIG_FREERTOS_TLSP_DELETION_CALLBACKS=n

# ---------------------------------------------------------------------------
# lwIP — IP reassembly for UDP JPEG streaming (large datagrams)
# ---------------------------------------------------------------------------
CONFIG_LWIP_IP_REASSEMBLY=y
CONFIG_LWIP_IP_REASS_MAX_PBUFS=64

# ---------------------------------------------------------------------------
# Memory — reserve internal RAM for DMA (SDIO WiFi + TCP buffers)
# 128KB is the minimum for concurrent voice WS + HTTP debug server + SDIO RX.
# Reducing below 128KB causes WiFi/TCP subsystem to spill into general heap.
# ---------------------------------------------------------------------------
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=131072

# ---------------------------------------------------------------------------
# SDIO WiFi stability — tuned for concurrent WS + HTTP traffic
# ---------------------------------------------------------------------------
CONFIG_ESP_HOSTED_DFLT_TASK_STACK=12288
CONFIG_ESP_HOSTED_RPC_TASK_STACK=12288
# Reduce SDIO RX queue depth to free ~30KB DMA heap for TCP buffers
CONFIG_ESP_HOSTED_SDIO_RX_Q_SIZE=20
CONFIG_ESP_SDIO_RX_Q_SIZE=20

# ---------------------------------------------------------------------------
# lwIP TCP — sized for concurrent voice WS + HTTP debug server
# ---------------------------------------------------------------------------
CONFIG_LWIP_MAX_SOCKETS=24
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=8192
CONFIG_LWIP_TCP_WND_DEFAULT=8192
CONFIG_LWIP_TCP_RECVMBOX_SIZE=12
CONFIG_LWIP_TCP_ACCEPTMBOX_SIZE=12
CONFIG_LWIP_TCP_OOSEQ_MAX_PBUFS=8
CONFIG_LWIP_TCPIP_TASK_STACK_SIZE=4096
# Pin LWIP to Core 1 — prevents TCP starvation during heavy LVGL rendering on Core 0.
# Settings creates 55 objects which blocks Core 0 for ~1s. Without this, LWIP
# gravitates to Core 0 and can't process SYN-ACK, causing 8s HTTP timeouts.
CONFIG_LWIP_TCPIP_TASK_AFFINITY_CPU1=y
# Camera SC202CS sensor
CONFIG_CAMERA_SC202CS=y
CONFIG_CAMERA_SC202CS_AUTO_DETECT=y
CONFIG_CAMERA_SC202CS_AUTO_DETECT_MIPI_INTERFACE_SENSOR=y
CONFIG_CAMERA_SC202CS_MIPI_RAW8_1280x720_30FPS=y
CONFIG_CAMERA_SC202CS_MIPI_IF_FORMAT_INDEX_DAFAULT=0

# LVGL TJPGD — JPEG decoder for media cache image rendering
CONFIG_LV_USE_TJPGD=y
# Memory-mapped FS — required for TJPGD to decode JPEG from RAM buffers
CONFIG_LV_USE_FS_MEMFS=y
CONFIG_LV_FS_MEMFS_LETTER=77
